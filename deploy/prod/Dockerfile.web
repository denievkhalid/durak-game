FROM node:22-alpine AS build

WORKDIR /app

COPY package.json package-lock.json turbo.json ./
COPY apps/game/package.json apps/game/package.json
COPY packages/engine/package.json packages/engine/package.json

RUN npm ci

COPY apps/game apps/game
COPY packages/engine packages/engine

ARG VITE_API_URL=/api
ARG VITE_SOCKET_URL=

ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_SOCKET_URL=${VITE_SOCKET_URL}

RUN npm run build --workspace @durakjs/game

FROM nginx:1.27-alpine

COPY deploy/prod/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/apps/game/dist /usr/share/nginx/html

EXPOSE 80
